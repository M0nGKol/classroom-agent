# Secrets - never commit
backend/.env
backend/credentials.json
backend/token.json
backend/client_secret_*.json

# Python
backend/__pycache__/
backend/**/__pycache__/
backend/.venv/
*.pyc

# Backend runtime data
backend/uploads/*
!backend/uploads/.gitkeep
backend/outputs/
backend/logs/

# Node / Next.js (frontend/.gitignore already covers this when present)
frontend/node_modules/
frontend/.next/
